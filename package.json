{
  "name": "@evref-bl/dev-nexus-typescript",
  "version": "0.1.0-alpha.1",
  "private": false,
  "description": "TypeScript and JavaScript tooling plugin for DevNexus worktrees.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Evref-BL/DevNexus-TypeScript.git"
  },
  "type": "module",
  "bin": {
    "dev-nexus-typescript": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "test": "vitest run",
    "check": "npm run build && npm test"
  },
  "dependencies": {
    "dev-nexus": "npm:@evref-bl/dev-nexus@0.1.0-alpha.16"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
